# Epic FHIR OAuth 2.0 credentials
# Register your app at https://fhir.epic.com/Developer/Apps
# For sandbox testing, use the Epic sandbox client ID from open.epic.com
EPIC_CLIENT_ID=your-client-id-here

# Where Epic will redirect after user login.
# Port 0 means the OS assigns a free port at runtime.
EPIC_REDIRECT_URI=http://localhost:0/callback

# Epic FHIR R4 base URL (sandbox)
EPIC_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# Epic OAuth endpoints (sandbox)
EPIC_AUTH_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token

# Where to store OAuth tokens between sessions (file is created with 0o600 permissions)
TOKEN_FILE_PATH=~/.epic-mcp-tokens.json

# Appointments beyond this distance (miles) get a "consider phone call" flag.
# Useful for cancer patients who travel far for infusion appointments.
PATIENT_DISTANCE_THRESHOLD_MILES=30
