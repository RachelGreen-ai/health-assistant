# Epic FHIR OAuth credentials
# Register your app at https://fhir.epic.com/Developer/Apps
EPIC_CLIENT_ID=your-epic-client-id-here

# OAuth redirect URI — must be HTTPS in production
EPIC_REDIRECT_URI=https://your-app.onrender.com/callback

# Epic FHIR endpoints — sandbox
EPIC_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_AUTH_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token

# Epic FHIR endpoints — Stanford production (update after Epic USCDI approval)
# EPIC_BASE_URL=https://sfd.stanfordmed.org/FHIR/api/FHIR/R4/
# EPIC_AUTH_URL=https://sfd.stanfordmed.org/FHIR/oauth2/authorize
# EPIC_TOKEN_URL=https://sfd.stanfordmed.org/FHIR/oauth2/token

# Token storage path
TOKEN_FILE_PATH=~/.epic-mcp-tokens.json

# Distance threshold for appointment travel flag (miles)
PATIENT_DISTANCE_THRESHOLD_MILES=30
