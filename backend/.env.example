# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — get from platform.openai.com (for Whisper STT + TTS)
OPENAI_API_KEY=sk-proj-...

# Epic FHIR — sandbox values below, replace with production values from Epic App Orchard
EPIC_CLIENT_ID=d952aa66-f0c5-481f-a610-d75912dd4ff3
EPIC_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_AUTH_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token

# For local dev: http://localhost:9090/callback
# For production: https://your-app.onrender.com/callback
EPIC_REDIRECT_URI=http://localhost:9090/callback

# Where to store OAuth tokens (use /tmp for cloud deployments)
TOKEN_FILE_PATH=/tmp/.epic-mcp-tokens.json

# How far to search for nearby providers (miles)
PATIENT_DISTANCE_THRESHOLD_MILES=30

# Model selection — haiku for dev (cheap), opus for prod
# CLAUDE_MODEL=claude-opus-4-6

# Server port
PORT=3000
